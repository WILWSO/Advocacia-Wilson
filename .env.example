# Configuração do Supabase
# Substitua pelos valores reais da sua instância do Supabase

# URL do projeto Supabase
VITE_SUPABASE_URL=your_supabase_project_url_here

# Chave pública anônima do Supabase
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Exemplo de como deve ficar:
# VITE_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=ey.......

# -----------------------------------------
# MAINTENANCE MODE CONFIGURATION
# -----------------------------------------

# Ativa/desativa o modo de manutenção
# true = Sistema bloqueado para usuários regulares
# false = Sistema funcionando normalmente
VITE_MAINTENANCE_MODE=false

# Lista de emails de desenvolvedores (separados por vírgula)
# Estes usuários terão acesso ao sistema mesmo durante manutenção
# Exemplo: admin@example.com,dev@example.com,suporte@example.com
VITE_MAINTENANCE_DEV_EMAILS=