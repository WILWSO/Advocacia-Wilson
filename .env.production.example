# =========================================
# CONFIGURACIÓN DE PRODUCCIÓN - Advocacia Wilson
# =========================================

# ⚠️ IMPORTANTE: Este es un archivo de ejemplo
# Copia este archivo como .env y completa con tus valores reales
# NUNCA subas el archivo .env al repositorio

# -----------------------------------------
# SUPABASE CONFIGURATION
# -----------------------------------------

# URL del proyecto Supabase
# Obtén este valor desde: Supabase Dashboard → Settings → API → Project URL
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública anónima de Supabase
# Obtén este valor desde: Supabase Dashboard → Settings → API → Project API keys → anon/public
VITE_SUPABASE_ANON_KEY=tu_anon_key_aqui

# -----------------------------------------
# NOTAS DE SEGURIDAD
# -----------------------------------------

# ✅ El archivo .env.local se usa automáticamente en desarrollo
# ✅ Para producción, configura estas variables en tu plataforma de hosting:
#    - Vercel: Settings → Environment Variables
#    - Netlify: Site settings → Environment variables
#    - Otros: Panel de control del hosting

# ⚠️ NUNCA expongas tu Service Role Key en el frontend
# ⚠️ NUNCA hagas commit del archivo .env al repositorio

# -----------------------------------------
# VALIDACIÓN
# -----------------------------------------

# Para verificar que las variables están configuradas correctamente:
# 1. Ejecuta: npm run dev
# 2. Revisa la consola del navegador
# 3. Si ves un error sobre variables de entorno, verifica este archivo
# -----------------------------------------
# MAINTENANCE MODE CONFIGURATION
# -----------------------------------------

# Activar/desactivar el modo de mantenimiento
# true = Sistema bloqueado para usuarios regulares
# false = Sistema funcionando normalmente
VITE_MAINTENANCE_MODE=false

# Lista de emails de desarrolladores (separados por coma, sin espacios)
# Estos usuarios tendrán acceso al sistema incluso durante mantenimiento
# Ejemplo: admin@example.com,dev1@example.com,dev2@example.com
VITE_MAINTENANCE_DEV_EMAILS=

# Cómo usar el modo de mantenimiento:
# 1. Para activar: Cambia VITE_MAINTENANCE_MODE=true
# 2. Agrega emails de DEVs en VITE_MAINTENANCE_DEV_EMAILS
# 3. Redeploy o reinicia el servidor de desarrollo
# 4. Usuarios regulares verán pantalla de mantenimiento
# 5. Usuarios en la lista verán un badge amarillo "Modo Desarrollador"